<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ title }}</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<style>
  :root {
    --bg: #fafaf7;
    --fg: #1a1a1a;
    --muted: #6b6b6b;
    --accent: #c96442;
    --accent-bg: #f6e8e0;
    --border: #e3e3df;
    --sidebar-w: 280px;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg);
    font: 16px/1.65 -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif; }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  .layout { display: grid; grid-template-columns: var(--sidebar-w) 1fr; min-height: 100vh; }
  aside.toc {
    position: sticky; top: 0; align-self: start; max-height: 100vh; overflow-y: auto;
    padding: 28px 20px; border-right: 1px solid var(--border); background: #fff;
    font-size: 14px;
  }
  aside.toc h2 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--muted); margin: 0 0 12px; }
  aside.toc ol { list-style: none; margin: 0; padding: 0; }
  aside.toc li { margin: 0 0 10px; }
  aside.toc a { color: var(--fg); display: block; }
  aside.toc a:hover { color: var(--accent); }
  aside.toc .num { color: var(--muted); margin-right: 6px; font-variant-numeric: tabular-nums; }

  main { padding: 40px clamp(24px, 6vw, 80px); max-width: 880px; }
  header.meta { border-bottom: 1px solid var(--border); padding-bottom: 24px; margin-bottom: 32px; }
  header.meta h1 { font-size: 28px; line-height: 1.25; margin: 0 0 12px; }
  header.meta .sub { color: var(--muted); font-size: 14px; }
  header.meta .sub a { color: var(--muted); }
  header.meta .sub a:hover { color: var(--accent); }

  section.chapter { margin: 40px 0; scroll-margin-top: 20px; }
  section.chapter h2 { font-size: 20px; margin: 0 0 16px; padding-bottom: 8px;
    border-bottom: 1px solid var(--border); }

  p.para { margin: 0 0 20px; position: relative; padding-left: 76px; }
  a.ts {
    position: absolute; left: 0; top: 4px;
    display: inline-block; min-width: 64px; text-align: center;
    padding: 2px 8px; border-radius: 4px;
    background: var(--accent-bg); color: var(--accent);
    font: 600 12px/1.4 ui-monospace, SFMono-Regular, Menlo, monospace;
    font-variant-numeric: tabular-nums;
  }
  a.ts:hover { background: var(--accent); color: #fff; text-decoration: none; }

  footer.meta { border-top: 1px solid var(--border); padding-top: 20px; margin-top: 48px;
    color: var(--muted); font-size: 13px; }

  @media (max-width: 720px) {
    .layout { grid-template-columns: 1fr; }
    aside.toc { position: static; max-height: none; border-right: none;
      border-bottom: 1px solid var(--border); }
    p.para { padding-left: 0; }
    a.ts { position: static; display: inline-block; margin-right: 8px; }
  }
</style>
</head>
<body>
<div class="layout">
  <aside class="toc">
    <h2>目录</h2>
    <ol>
      {% for ch in chapters %}
      <li><a href="#sec-{{ loop.index }}"><span class="num">{{ '%02d' % loop.index }}</span>{{ ch.title }}</a></li>
      {% endfor %}
    </ol>
  </aside>
  <main>
    <header class="meta">
      <h1>{{ title }}</h1>
      <div class="sub">
        {{ uploader }} · {{ duration_hms }} · {{ upload_date_fmt }} ·
        <a href="{{ yt_url }}" target="_blank" rel="noopener">YouTube ↗</a>
      </div>
    </header>

    {% for ch in chapters %}
    <section class="chapter" id="sec-{{ loop.index }}">
      <h2>{{ '%02d' % loop.index }} · {{ ch.title }}</h2>
      {% for p in ch.paragraphs %}
      <p class="para">
        <a class="ts" href="{{ yt_url }}&t={{ p.start|int }}s" target="_blank"
           rel="noopener" title="跳转到 YouTube 该时间点">{{ p.start|hms }}</a>
        {{ p.text }}
      </p>
      {% endfor %}
    </section>
    {% endfor %}

    <footer class="meta">
      字幕来源：YouTube 人工/自动字幕 · 段落由脚本自动分段 · 时间戳点击跳转 YouTube
    </footer>
  </main>
</div>
</body>
</html>
