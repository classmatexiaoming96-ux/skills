#!/bin/bash
# ============================================================
# 企业代理配置 — 填写你的公司实际值后保存为 /etc/mihomo/env.sh
# ============================================================
# 本文件是唯一需要手动填写的；所有脚本自动读取它。
# 复制本文件后改权限：chmod 600 /etc/mihomo/env.sh
# ============================================================

# ──── 企业 HTTP 正向代理 ────
# ⚠️ 必须用 IP，不能用域名（Mihomo fake-ip 会拦截域名解析）
# 询问你的 IT 部门，或从浏览器代理设置中获取
ENTERPRISE_PROXY_IP="10.x.x.x"
ENTERPRISE_PROXY_PORT="8118"

# ──── 内网 DNS 服务器 ────
# 从 /etc/resolv.conf 获取
INTERNAL_DNS_1="10.x.x.x"
INTERNAL_DNS_2="10.x.x.x"

# ──── 内网域名后缀列表 ────
# 用逗号分隔，半角句点开头（适应 yaml 格式）
# 例：INTERNAL_DOMAINS="+.example.com,+.corp.local,+.internal.io"
# 例：INTERNAL_DOMAINS="+.byted.org,+.bytedance.net,+.tiktok-row.org,+.tiktok-row.net"
INTERNAL_DOMAINS="+.your-company.com,+.your-internal.net"

# ──── Mihomo 控制面板 ────
WEB_UI_SECRET="change-me-to-a-random-secret"
MIHOMO_HTTP_PORT="7890"
MIHOMO_SOCKS_PORT="7891"
MIHOMO_API_PORT="9090"

# ──── NO_PROXY 排除列表 ────
# 逗号分隔，供 Claude Code / curl 等工具使用
# 把 INTERNAL_DOMAINS 里的 "+." 去掉后填入
NO_PROXY_LIST="localhost,127.0.0.1,your-company.com,your-internal.net"
